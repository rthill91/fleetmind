#!/bin/sh
set -eu

PORT="$(snapctl get port)"
case "$PORT" in
    '')
        snapctl set port=8765
        ;;
    *[!0-9]*)
        echo "fleetmind: port must be numeric, got '$PORT'" >&2
        exit 1
        ;;
    *)
        if [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
            echo "fleetmind: port '$PORT' out of range (1-65535)" >&2
            exit 1
        fi
        ;;
esac

BIND="$(snapctl get bind)"
case "$BIND" in
    ''|127.0.0.1|0.0.0.0)
        ;;
    *)
        echo "fleetmind: bind must be 127.0.0.1 or 0.0.0.0, got '$BIND'" >&2
        exit 1
        ;;
esac

FLEET="$(snapctl get fleet)"
case "$FLEET" in
    ''|0|1|true|false|yes|no|on|off) ;;
    *)
        echo "fleetmind: fleet must be one of 0/1/true/false/yes/no/on/off, got '$FLEET'" >&2
        exit 1
        ;;
esac

JOIN_URL="$(snapctl get join-url)"
case "$JOIN_URL" in
    ''|http://*|https://*) ;;
    *)
        echo "fleetmind: join-url must be http:// or https://, got '$JOIN_URL'" >&2
        exit 1
        ;;
esac

ADVERTISE_URL="$(snapctl get advertise-url)"
case "$ADVERTISE_URL" in
    ''|http://*|https://*) ;;
    *)
        echo "fleetmind: advertise-url must be http:// or https://, got '$ADVERTISE_URL'" >&2
        exit 1
        ;;
esac
